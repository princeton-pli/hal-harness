{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Ruff: Check",
      "type": "shell",
      "command": "ruff check . && ruff format --check .",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Ruff: Fix and Format",
      "type": "shell",
      "command": "ruff check --fix . && ruff format .",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Prefect: server",
      "type": "shell",
      "command": ".venv/bin/prefect server start",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "prefect"
      }
    },
    {
      "label": "Prefect: flow",
      "type": "shell",
      "command": ".venv/bin/python prefect/flow.py",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "prefect"
      }
    },
    {
      "label": "Run prefect server and flow.py",
      "dependsOn": ["Prefect: server", "Prefect: flow"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": ".venv/bin/python -m pytest tests/ -v",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
